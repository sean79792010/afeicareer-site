---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const speaking = await getEntry("pages", "speaking");

if (!speaking) {
  throw new Error(
    "Missing content entry: `speaking.md` or `speaking.mdx` in `src/content/pages/`"
  );
}

const { Content } = await render(speaking);
---

<Layout
  title={`${speaking.data.title} | ${config.site.title}`}
  description={speaking.data.description}
  ogImage={speaking.data.ogImage}
  canonicalURL={speaking.data.canonicalURL}
>
  <Header />

  <Breadcrumb />

  <Main pageTitle={speaking.data.title} class="app-prose">
    <Content />
  </Main>

  <Footer />
</Layout>
