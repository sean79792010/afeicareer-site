---
import { getEntry, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const pricing = await getEntry("pages", "pricing");

if (!pricing) {
  throw new Error(
    "Missing content entry: `pricing.md` or `pricing.mdx` in `src/content/pages/`"
  );
}

const { Content } = await render(pricing);
---

<Layout
  title={`${pricing.data.title} | ${config.site.title}`}
  description={pricing.data.description}
  ogImage={pricing.data.ogImage}
  canonicalURL={pricing.data.canonicalURL}
>
  <Header />

  <Breadcrumb />

  <Main pageTitle={pricing.data.title} class="app-prose">
    <Content />
  </Main>

  <Footer />
</Layout>
